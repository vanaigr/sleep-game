<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="0">

        </FrameLayout>

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:text="Как поспали?"
            android:textAlignment="center" />

        <ImageButton
            android:id="@+id/cancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="0"
            android:background="@android:color/transparent"
            android:cropToPadding="false"
            android:padding="8dp"
            app:srcCompat="@android:drawable/ic_menu_close_clear_cancel" />

    </LinearLayout>

    <Button
        android:id="@+id/ideal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Замечательно" />

    <Button
        android:id="@+id/not_ideal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Не идеально" />

    <Button
        android:id="@+id/not_good"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Не очень" />

    <Button
        android:id="@+id/terrible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ужасно" />

    <Button
        android:id="@+id/no_sleep"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Не спал" />
</LinearLayout>